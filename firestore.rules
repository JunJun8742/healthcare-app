rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function myRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isStaffOrAdmin() {
      return isSignedIn() && myRole() in ['staff', 'admin'];
    }

    function isAdmin() {
      return isSignedIn() && myRole() == 'admin';
    }

    // users/{uid}
    // NOTE: admin accounts cannot be self-created under this rule by design —
    // admins are provisioned manually via the Firebase console.
    match /users/{uid} {
      // Any signed-in user (e.g. a patient browsing BookingScreen's staff
      // picker) may read staff profiles; self/staff/admin reads unchanged.
      allow read: if isSignedIn() && (request.auth.uid == uid || isStaffOrAdmin() || resource.data.role == 'staff');
      allow create: if isSignedIn() && request.auth.uid == uid && (
        request.resource.data.role == 'patient' ||
        (request.resource.data.role == 'staff' &&
          request.resource.data.inviteCode ==
            get(/databases/$(database)/documents/settings/staff_invite).data.invite_code)
      );
      allow update: if isSignedIn() && request.auth.uid == uid &&
        request.resource.data.role == resource.data.role;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // appointments/{id}
    match /appointments/{id} {
      allow read: if isSignedIn() && (resource.data.patientUid == request.auth.uid || isStaffOrAdmin());
      allow create: if isSignedIn() && request.resource.data.patientUid == request.auth.uid;
      // Patients may only cancel their own waiting appointment, touching only
      // the cancel fields. cancelledBy is optional (older APKs don't send it —
      // hasOnly permits a subset), so legacy clients keep working.
      allow update: if isSignedIn() && resource.data.patientUid == request.auth.uid &&
        resource.data.status == 'กำลังรอ' &&
        request.resource.data.status == 'ยกเลิก' &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'cancelledAt', 'cancelledBy']);
      allow update: if isStaffOrAdmin();
      allow delete: if isAdmin();
    }

    // queue_days/{dateStr} — global per-day queue-number counter used by the booking
    // transaction. `count` may only ever go up by exactly 1 per write.
    match /queue_days/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.diff({}).affectedKeys().hasOnly(['date', 'count']) &&
        request.resource.data.count == 1;
      allow update: if isSignedIn() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['date', 'count']) &&
        request.resource.data.count == resource.data.count + 1;
    }

    // queue_slots/{staffUid}_{dateStr} — per-staff slot lock used by the booking
    // transaction. `bookedTimes` values are appointment-doc-id strings while a
    // slot is booked. Keys are add-only (never removed). An existing key's
    // value may only flip string -> false when the linked appointment is
    // really cancelled (slot release), or false -> string when the new linked
    // appointment exists and isn't cancelled (staff undo re-lock).
    match /queue_slots/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.diff({}).affectedKeys().hasOnly(['staffUid', 'date', 'bookedTimes']) &&
        request.resource.data.bookedTimes.size() == 1 &&
        request.resource.data.bookedTimes.values()[0] is string &&
        request.resource.data.bookedTimes.values()[0].size() > 0;
      allow update: if isSignedIn() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['bookedTimes']) &&
        request.resource.data.bookedTimes.keys().hasAll(resource.data.bookedTimes.keys()) &&
        (
          // (i) add-only: brand new time-slot keys added, nothing existing changed.
          (
            request.resource.data.bookedTimes.diff(resource.data.bookedTimes).removedKeys().size() == 0 &&
            request.resource.data.bookedTimes.diff(resource.data.bookedTimes).changedKeys().size() == 0 &&
            request.resource.data.bookedTimes.diff(resource.data.bookedTimes).addedKeys().size() == 1
          ) ||
          // (ii) exactly one existing key flips value: release (string -> false)
          // when the linked appointment is cancelled, or re-lock (false -> string)
          // when the newly-linked appointment exists and isn't cancelled.
          (
            request.resource.data.bookedTimes.diff(resource.data.bookedTimes).addedKeys().size() == 0 &&
            request.resource.data.bookedTimes.diff(resource.data.bookedTimes).removedKeys().size() == 0 &&
            request.resource.data.bookedTimes.diff(resource.data.bookedTimes).changedKeys().size() == 1
          )
        );
    }

    // sos_alerts/{id}
    match /sos_alerts/{id} {
      allow read: if isStaffOrAdmin();
      allow create: if isSignedIn() && request.resource.data.patientUid == request.auth.uid;
      allow update: if isStaffOrAdmin();
      allow delete: if isAdmin();
    }

    // staff_availability/{id}
    match /staff_availability/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.resource.data.staffUid == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.staffUid == request.auth.uid || isAdmin());
    }

    // machine_status/{id} — ESP32 devices write without Firebase Auth today,
    // so writes are open but restricted to the heartbeat fields only.
    // Known limitation accepted for Phase 1; replace with device auth later.
    match /machine_status/{id} {
      allow read: if isSignedIn();
      allow write: if request.resource.data.keys().hasOnly(['is_active', 'last_updated']);
    }

    // settings/staff_invite — read during staff signup, before the user is
    // authenticated, and also validated server-side by the users/{uid} create
    // rule above. Narrowed to this exact doc (was a wildcard over all of
    // settings/{id}).
    match /settings/staff_invite {
      allow read: if true;
      allow write: if isAdmin();
    }

    // notifications/{id} — push-notification history, written ONLY by Cloud
    // Functions via the Admin SDK (which bypasses these rules). Clients may
    // read their own docs and flip read false -> true; nothing else.
    match /notifications/{id} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow update: if isSignedIn() && resource.data.uid == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']) &&
        resource.data.read == false &&
        request.resource.data.read == true;
      allow create, delete: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
